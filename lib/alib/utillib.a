;   autoinit if you ever reference UTILITY.LIBRARY
;
;
;   can't use pc-relative between different code sections
;   and cannot put string in autoinit section!
;
; SPDX-License-Identifier: BSD-3-Clause
;
; Licensed to you under the terms of the 3-clause BSD license.
; See the LICENSE file at the root of this project for details.
; Copyright 1990 Matthew Dillon

                        xdef    _UtilityBase
                        xref    __AutoFail0

_LVOOpenLibrary         equ     -552
_LVOCloseLibrary        equ     -414

                        section autoinit0,code

                        moveq.l #0,D0
                        lea     utilname(pc),A1
                        jsr     _LVOOpenLibrary(A6)
                        move.l  D0,_UtilityBase(A4)
                        beq     __AutoFail0
                        bra     i10
utilname                dc.b    'utility.library',0
                        ds.w    0
i10

                        section autoexit0,code

                        move.l  _UtilityBase(A4),D0
                        beq     l10
                        move.l  D0,A1
                        jsr     _LVOCloseLibrary(A6)
l10


                        section libbss,bss

_UtilityBase            ds.l    1

                        END

