; See the LICENSE file at the root of this project for details.
; Copyright 1992-1997 Obvious Implementations Corp

                section text,code

                xdef    _ReadEClock
                xdef    @ReadEClock
                xref    _DOSBase

_ReadEClock:
                move.l  8(sp),A0
@ReadEClock:
                move.l  A6,-(sp)
                move.l  _DOSBase(A4),A6
                jsr     $FFFFFFC4(A6)
                move.l  (sp)+,A6
                rts

                END

