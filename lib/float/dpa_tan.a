                ;   DTAN.A
                ;
                ;   D0/D1 = tan(D0/D1)
                ;               4(sp)
                ;

                section text,code

                xref    _MathIeeeDoubTransBase
                xref    _LVOIEEEDPTan
                xdef    _tan

_tan            movem.l 4(sp),D0/D1
                move.l  A6,-(sp)
                move.l  _MathIeeeDoubTransBase(A4),A6
                jsr     _LVOIEEEDPTan(A6)
                move.l  (sp)+,A6
                rts

                END

