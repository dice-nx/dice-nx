                ;   DPOW.A
                ;
                ;   D0/D1 = pow(D0/D1, D2/D3)
                ;               4(sp)  12(sp)
                ;

                section text,code

                xref    _MathIeeeDoubTransBase
                xref    _LVOIEEEDPPow
                xdef    _pow

_pow            movem.l D2-D3/A6,-(sp)
                movem.l 4+12(sp),D0-D3
                move.l  _MathIeeeDoubTransBase(A4),A6
                jsr     _LVOIEEEDPPow(A6)
                movem.l (sp)+,D2-D3/A6
                rts

                END

