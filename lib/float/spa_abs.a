                ;   FFABS.A
                ;
                ;   D0 = ffabs(D0)
                ;             4(sp)
                ;

                section text,code

                xref    _MathIeeeSingBasBase
                xref    _LVOIEEESPAbs
                xdef    __spabs

__spabs         move.l  4(sp),D0
                move.l  A6,-(sp)
                move.l  _MathIeeeSingBasBase(A4),A6
                jsr     _LVOIEEESPAbs(A6)
                move.l  (sp)+,A6
                rts

                END

