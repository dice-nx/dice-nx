                ;   FFPA_LOG10.A
                ;
                ;   D0 = ffplog10(D0)
                ;              4(sp)
                ;

                section text,code

                xref    _MathTransBase
                xref    _LVOSPLog10
                xdef    __ffplog10

__ffplog10      move.l  4(sp),D0
                move.l  A6,-(sp)
                move.l  _MathTransBase(A4),A6
                jsr     _LVOSPLog10(A6)
                move.l  (sp)+,A6
                rts

                END

