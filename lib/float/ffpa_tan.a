                ;   FFPA_TAN.A
                ;
                ;   D0 = ftan(D0)
                ;             4(sp)
                ;

                section text,code

                xref    _MathTransBase
                xref    _LVOSPTan
                xdef    __ffptan

__ffptan        move.l  4(sp),D0
                move.l  A6,-(sp)
                move.l  _MathTransBase(A4),A6
                jsr     _LVOSPTan(A6)
                move.l  (sp)+,A6
                rts

                END

