                ;   FFPA_POW.A
                ;
                ;   D0 = ffppow(D0, D1)
                ;             4(sp) 8(sp)
                ;

                section text,code

                xref    _MathTransBase
                xref    _LVOSPPow
                xdef    __ffppow

__ffppow        movem.l 4(sp),D0/D1
                move.l  A6,-(sp)
                move.l  _MathTransBase(A4),A6
                jsr     _LVOSPPow(A6)
                move.l  (sp)+,A6
                rts

                END

