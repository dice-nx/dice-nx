                ;   FFPA_ADD.A
                ;
                ;   D0  arg1    (4 bytes)
                ;   D1  arg2    (4 bytes)
                ;
                ;   result -> D0
                ;

                section text,code

                xref    _MathBase
                xref    _LVOSPAdd
                xdef    __ffpadd_a

__ffpadd_a      move.l  A6,-(sp)
                move.l  _MathBase(A4),A6
                jsr     _LVOSPAdd(A6)
                move.l  (sp)+,A6
                rts

                END

