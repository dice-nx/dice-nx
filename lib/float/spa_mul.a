                ;   SPA_MUL.A
                ;
                ;   D0  arg1    (4 bytes)
                ;   D1  arg2    (4 bytes)
                ;
                ;   result -> D0
                ;

                section text,code

                xref    _MathIeeeSingBasBase
                xref    _LVOIEEESPMul
                xdef    __spmul_a

__spmul_a       move.l  A6,-(sp)
                move.l  _MathIeeeSingBasBase(A4),A6
                jsr     _LVOIEEESPMul(A6)
                move.l  (sp)+,A6
                rts

                END

