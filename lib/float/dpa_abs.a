                ;   DABS.A
                ;
                ;   D0/D1 = fabs(D0/D1)
                ;               4(sp)
                ;

                section text,code

                xref    _MathIeeeDoubBasBase
                xref    _LVOIEEEDPAbs
                xdef    _fabs

_fabs           movem.l 4(sp),D0/D1
                move.l  A6,-(sp)
                move.l  _MathIeeeDoubBasBase(A4),A6
                jsr     _LVOIEEEDPAbs(A6)
                move.l  (sp)+,A6
                rts

                END

