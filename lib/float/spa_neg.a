                ;   SPA_NEG.A
                ;
                ;   D0  integer arg
                ;   result float in D0
                ;

                section text,code

                xref    _MathIeeeSingBasBase
                xref    _LVOIEEESPNeg
                xdef    __spneg_a

__spneg_a       move.l  A6,-(sp)
                move.l  _MathIeeeSingBasBase(A4),A6
                jsr     _LVOIEEESPNeg(A6)
                move.l  (sp)+,A6
                rts

                END

