                ;   FPOW.A
                ;
                ;   D0 = fpow(D0, D1)
                ;             4(sp) 8(sp)
                ;

                section text,code

                xref    _MathIeeeSingTransBase
                xref    _LVOIEEESPPow
                xdef    __sppow

__sppow         movem.l 4(sp),D0/D1
                move.l  A6,-(sp)
                move.l  _MathIeeeSingTransBase(A4),A6
                jsr     _LVOIEEESPPow(A6)
                move.l  (sp)+,A6
                rts

                END

