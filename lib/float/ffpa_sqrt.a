                ;   FFPA_SQRT.A
                ;
                ;   D0 = ffpsqrt(D0)
                ;             4(sp)
                ;

                section text,code

                xref    _MathTransBase
                xref    _LVOSPSqrt
                xdef    __ffpsqrt

__ffpsqrt       move.l  4(sp),D0
                move.l  A6,-(sp)
                move.l  _MathTransBase(A4),A6
                jsr     _LVOSPSqrt(A6)
                move.l  (sp)+,A6
                rts

                END

