                ;   FFPA_ATAN.A
                ;
                ;   D0 = ffpatan(D0)
                ;              4(sp)
                ;

                section text,code

                xref    _MathTransBase
                xref    _LVOSPAtan
                xdef    __ffpatan

__ffpatan       move.l  4(sp),D0
                move.l  A6,-(sp)
                move.l  _MathTransBase(A4),A6
                jsr     _LVOSPAtan(A6)
                move.l  (sp)+,A6
                rts

                END

