                ;   DPA_CMP.A
                ;
                ;   A0  arg1    (8 bytes)
                ;   A1  arg2    (8 bytes)
                ;

                section text,code

                xref    _MathIeeeDoubBasBase
                xref    _LVOIEEEDPCmp
                xdef    __dpcmp_a

__dpcmp_a       movem.l D2/D3/A6,-(sp)
                move.l  _MathIeeeDoubBasBase(A4),A6
                movem.l (A0),D0/D1
                movem.l (A1),D2/D3
                jsr     _LVOIEEEDPCmp(A6)
                movem.l (sp)+,D2/D3/A6
                tst.l   D0
                rts

                END

