                ;   SPA_SQRT.A
                ;
                ;   D0 = fsqrt(D0)
                ;             4(sp)
                ;

                section text,code

                xref    _MathIeeeSingTransBase
                xref    _LVOIEEESPSqrt
                xdef    __spsqrt

__spsqrt        move.l  4(sp),D0
                move.l  A6,-(sp)
                move.l  _MathIeeeSingTransBase(A4),A6
                jsr     _LVOIEEESPSqrt(A6)
                move.l  (sp)+,A6
                rts

                END

