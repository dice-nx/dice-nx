                ;   DCEIL.A
                ;
                ;   D0/D1 = ceil(D0/D1)
                ;               4(sp)
                ;

                section text,code

                xref    _MathIeeeDoubBasBase
                xref    _LVOIEEEDPCeil
                xdef    _ceil

_ceil           movem.l 4(sp),D0/D1
                move.l  A6,-(sp)
                move.l  _MathIeeeDoubBasBase(A4),A6
                jsr     _LVOIEEEDPCeil(A6)
                move.l  (sp)+,A6
                rts

                END

