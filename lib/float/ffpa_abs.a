                ;   FFPA_ABS.A
                ;
                ;   D0 = ffpabs(D0)
                ;             4(sp)
                ;

                section text,code

                xref    _MathBase
                xref    _LVOSPAbs
                xdef    __ffpabs

__ffpabs        move.l  4(sp),D0
                move.l  A6,-(sp)
                move.l  _MathBase(A4),A6
                jsr     _LVOSPAbs(A6)
                move.l  (sp)+,A6
                rts

                END

