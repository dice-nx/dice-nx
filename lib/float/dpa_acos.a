                ;   DACOS.A
                ;
                ;   D0/D1 = acos(D0/D1)
                ;                4(sp)
                ;

                section text,code

                xref    _MathIeeeDoubTransBase
                xref    _LVOIEEEDPAcos
                xdef    _acos

_acos           movem.l 4(sp),D0/D1
                move.l  A6,-(sp)
                move.l  _MathIeeeDoubTransBase(A4),A6
                jsr     _LVOIEEEDPAcos(A6)
                move.l  (sp)+,A6
                rts

                END

