                ;   SPA_TST.A
                ;
                ;   D0  arg1    (4 bytes)
                ;

                section text,code

                xref    _MathIeeeSingBasBase
                xref    _LVOIEEESPTst
                xdef    __sptst_a

__sptst_a
                ;movem.l D0/D1/A0/A1/A6,-(sp)
                move.l  A6,-(sp)
                move.l  _MathIeeeSingBasBase(A4),A6
                move.l  D0,D1
                jsr     _LVOIEEESPTst(A6)
                ;movem.l (sp)+,D0/D1/A0/A1/A6
                move.l  (sp)+,A6
                rts

                END

