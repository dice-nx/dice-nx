                ;   FSIN.A
                ;
                ;   D0 = fsin(D0)
                ;             4(sp)
                ;

                section text,code

                xref    _MathIeeeSingTransBase
                xref    _LVOIEEESPSin
                xdef    __spsin

__spsin         move.l  4(sp),D0
                move.l  A6,-(sp)
                move.l  _MathIeeeSingTransBase(A4),A6
                jsr     _LVOIEEESPSin(A6)
                move.l  (sp)+,A6
                rts

                END

