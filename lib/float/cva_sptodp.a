                ;   CVA_SPTODP.A
                ;
                ;   D0 = arg    (4 bytes)
                ;
                ;   result in D0/D1
                ;

                section text,code

                xref    _MathIeeeDoubTransBase

                xref    _LVOIEEEDPFieee ; MathIeeeDoubTransBase (sing->doub)
                xdef    __cvsptodp_a

__cvsptodp_a    move.l  A6,-(sp)
                move.l  _MathIeeeDoubTransBase(A4),A6
                jsr     _LVOIEEEDPFieee(A6) ; convert ieee.sing->ieee.doub
                move.l  (sp)+,A6
                rts

                END

